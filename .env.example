# ioBroker SimpleAPI base URL (no trailing slash, no path)
# Example: http://192.168.178.152:8087
IOBROKER_URL=http://192.168.178.152:8087

# Authentication — leave empty for LAN-open installs (the default in
# ioBroker SimpleAPI when "Authentifizierung" is off). If you enable
# auth in the adapter, set both:
# IOBROKER_USER=
# IOBROKER_PASS=

# Optional: HTTP timeout in seconds (default 10)
# IOBROKER_TIMEOUT=10
